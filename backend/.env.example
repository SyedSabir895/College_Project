# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/college_task_manager
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/college_task_manager

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here
JWT_SECRET=your-secret-key-here

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# Flask Environment
FLASK_ENV=production
DEBUG=False
PORT=5000

# ===== SMTP/EMAIL CONFIGURATION (REQUIRED FOR PRODUCTION) =====
# 
# If using Gmail:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://myaccount.google.com/app-passwords
# 3. Generate an App Password (select Mail and Windows PC)
# 4. Use the 16-character password below (remove spaces)
#
# Example: If your app password is "abcd efgh ijkl mnop"
#   MAIL_USERNAME=your-email@gmail.com
#   MAIL_PASSWORD=abcdefghijklmnop
#

# Gmail Configuration (Recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password-here

# Alternative: Custom SMTP Server
# MAIL_SERVER=smtp.your-email-provider.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=your-email@your-domain.com
# MAIL_PASSWORD=your-smtp-password

# Email Sender Configuration
MAIL_DEFAULT_SENDER=NRI-AIML <your-email@gmail.com>

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.com

# Testing Configuration (Set to 'true' to suppress actual email sending during tests)
MAIL_SUPPRESS_SEND=false
